# Aegis Confidential Concierge Deployment Secrets
# RENAME THIS TO .env IN THE /apps/contracts/ DIRECTORY

# 1. Deployment Account (CFO Master ID)
# WARNING: NEVER SHARE OR COMMIT THIS KEY
PRIVATE_KEY=your_private_key_here

# 2. Blockchain Explorer Verification
# Get one at: https://celoscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# 3. Network Reporting
REPORT_GAS=true
